<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title id="meta-title">Hijrah Sisters IIUMK | Growing in Faith, Knowledge & Sisterhood</title>
    <meta name="description" content="A safe space for every Muslimah to grow in faith, knowledge, and sisterhood.">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Tailwind Configuration -->
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        blush: {
                            50: '#FDF2F6',
                            100: '#FCE7EF', // Primary requested color
                            200: '#F8C8DA',
                            300: '#F39DBF',
                            400: '#EB6A9D',
                            500: '#E03C7A',
                            600: '#C7245D',
                            900: '#5A122B', // For text
                        },
                        beige: '#F5F5DC',
                        gold: '#D4AF37',
                        darkBg: '#231E1F',
                        darkCard: '#2E2729',
                    },
                    fontFamily: {
                        serif: ['"Playfair Display"', 'serif'],
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <style>
        /* Custom CSS for features not easily handled by Tailwind utilities alone */
        
        /* Smooth Fade-In Animation on Scroll */
        .fade-in-section {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease-out, transform 0.8s ease-out;
            will-change: opacity, visibility;
        }
        .fade-in-section.is-visible {
            opacity: 1;
            transform: none;
        }

        /* Masonry Gallery */
        .masonry {
            column-count: 1;
            column-gap: 1rem;
        }
        @media (min-width: 640px) { .masonry { column-count: 2; } }
        @media (min-width: 1024px) { .masonry { column-count: 3; } }
        .masonry-item {
            break-inside: avoid;
            margin-bottom: 1rem;
        }

        /* Horizontal scrolling for Testimonials */
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        /* Islamic Geometric subtle background */
        .bg-pattern {
            background-image: url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23D4AF37" fill-opacity="0.05"%3E%3Cpath d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');
        }

        /* Lightbox styling */
        #lightbox { display: none; }
        #lightbox.active { display: flex; }
    </style>
</head>
<body class="font-sans bg-white dark:bg-darkBg text-gray-800 dark:text-gray-200 transition-colors duration-300 antialiased relative">

    <!-- Sticky Navigation -->
    <header class="fixed w-full top-0 z-50 bg-white/90 dark:bg-darkBg/90 backdrop-blur-md shadow-sm transition-colors duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <!-- Logo -->
                <a href="#" class="flex items-center gap-2">
                    <i class="fa-solid fa-leaf text-blush-500 text-xl"></i>
                    <div>
                        <h1 id="site-name-text" class="font-serif font-bold text-xl text-blush-900 dark:text-blush-200 leading-none">Hijrah Sisters</h1>
                        <span class="text-[10px] tracking-widest uppercase text-gray-500 dark:text-gray-400">IIUMK</span>
                    </div>
                </a>

                <!-- Desktop Menu -->
                <nav class="hidden md:flex space-x-8 items-center">
                    <a href="#home" class="text-sm font-medium hover:text-blush-500 transition-colors">Home</a>
                    <a href="#about" class="text-sm font-medium hover:text-blush-500 transition-colors">About Us</a>
                    <a href="#events" class="text-sm font-medium hover:text-blush-500 transition-colors">Events</a>
                    <a href="#resources" class="text-sm font-medium hover:text-blush-500 transition-colors">Resources</a>
                    <a href="#gallery" class="text-sm font-medium hover:text-blush-500 transition-colors">Gallery</a>
                    
                    <!-- Dark Mode Toggle -->
                    <button id="theme-toggle" class="text-gray-500 hover:text-blush-500 focus:outline-none transition-colors">
                        <i id="theme-icon" class="fa-solid fa-moon"></i>
                    </button>

                    <a id="join-nav-btn" href="#join" class="bg-blush-500 hover:bg-blush-600 text-white px-5 py-2.5 rounded-full text-sm font-medium transition-colors shadow-sm">Join Our Circle</a>
                </nav>

                <!-- Mobile Menu Button -->
                <div class="md:hidden flex items-center gap-4">
                    <button id="theme-toggle-mobile" class="text-gray-500 hover:text-blush-500 focus:outline-none">
                        <i id="theme-icon-mobile" class="fa-solid fa-moon"></i>
                    </button>
                    <button id="mobile-menu-btn" class="text-gray-800 dark:text-white focus:outline-none">
                        <i class="fa-solid fa-bars text-2xl"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Mobile Menu Panel -->
        <div id="mobile-menu" class="hidden md:hidden bg-white dark:bg-darkBg border-t border-gray-100 dark:border-gray-800">
            <div class="px-4 pt-2 pb-6 space-y-1 shadow-lg">
                <a href="#home" class="block px-3 py-3 text-base font-medium hover:bg-blush-50 dark:hover:bg-darkCard rounded-md mobile-link">Home</a>
                <a href="#about" class="block px-3 py-3 text-base font-medium hover:bg-blush-50 dark:hover:bg-darkCard rounded-md mobile-link">About Us</a>
                <a href="#events" class="block px-3 py-3 text-base font-medium hover:bg-blush-50 dark:hover:bg-darkCard rounded-md mobile-link">Events</a>
                <a href="#resources" class="block px-3 py-3 text-base font-medium hover:bg-blush-50 dark:hover:bg-darkCard rounded-md mobile-link">Resources</a>
                <a href="#gallery" class="block px-3 py-3 text-base font-medium hover:bg-blush-50 dark:hover:bg-darkCard rounded-md mobile-link">Gallery</a>
                <a href="#join" class="block mt-4 text-center bg-blush-500 text-white px-3 py-3 rounded-md text-base font-medium mobile-link">Join Our Circle</a>
            </div>
        </div>
    </header>

    <main class="pt-20">
        <!-- Hero Section -->
        <section id="home" class="relative min-h-[90vh] flex items-center bg-blush-50 dark:bg-darkBg overflow-hidden">
            <!-- Decorative background elements -->
            <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-blush-100 dark:bg-darkCard opacity-50 blur-3xl"></div>
            <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-72 h-72 rounded-full bg-beige dark:bg-blush-900 opacity-30 blur-3xl"></div>

            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full py-12 lg:py-0">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                    <div class="text-center lg:text-left fade-in-section">
                        <span id="hero-tagline" class="text-gold font-medium tracking-wider uppercase text-sm mb-4 block">Growing in Faith, Knowledge & Sisterhood</span>
                        <h2 id="hero-title-text" class="font-serif text-5xl lg:text-6xl font-bold text-blush-900 dark:text-white leading-tight mb-6">
                            A Safe Space for Every Muslimah to Grow
                        </h2>
                        <p id="hero-desc-text" class="text-lg text-gray-600 dark:text-gray-300 mb-8 max-w-lg mx-auto lg:mx-0 leading-relaxed">
                            "Building hearts connected to Allah through knowledge, sincere sisterhood, and meaningful reminders."
                        </p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
                            <a href="#join" class="bg-blush-500 hover:bg-blush-600 text-white px-8 py-3.5 rounded-full font-medium transition-all transform hover:-translate-y-1 shadow-lg shadow-blush-200 dark:shadow-none text-center">Join Our Circle</a>
                            <a href="#events" class="bg-white dark:bg-darkCard border border-blush-200 dark:border-gray-700 hover:border-blush-400 dark:hover:border-blush-400 text-blush-900 dark:text-white px-8 py-3.5 rounded-full font-medium transition-all text-center">Explore Events</a>
                        </div>
                    </div>
                    <div class="fade-in-section hidden lg:block">
                        <div class="relative">
                            <img id="hero-img-el" src="https://images.unsplash.com/photo-1542826438-bd32f43d626f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Muslimah aesthetic - books and tea" class="rounded-t-full rounded-bl-full shadow-2xl object-cover h-[500px] w-full border-4 border-white dark:border-darkCard">
                            <div class="absolute -bottom-6 -left-6 bg-white dark:bg-darkCard p-4 rounded-2xl shadow-xl flex items-center gap-4">
                                <div class="bg-blush-100 dark:bg-blush-900/50 p-3 rounded-full text-blush-600 dark:text-blush-200">
                                    <i class="fa-solid fa-quran text-xl"></i>
                                </div>
                                <div>
                                    <p id="next-gathering-title" class="text-sm text-gray-500 dark:text-gray-400">Next Gathering</p>
                                    <p id="next-gathering-sub" class="font-bold text-blush-900 dark:text-white">Friday Usrah</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- About Us -->
        <section id="about" class="py-24 bg-white dark:bg-darkCard relative overflow-hidden bg-pattern">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    <div class="order-2 lg:order-1 fade-in-section">
                        <div class="relative p-2">
                            <!-- Subtle gold border effect -->
                            <div class="absolute inset-0 border-2 border-gold/30 rounded-3xl transform translate-x-4 translate-y-4"></div>
                            <img id="about-img-el" src="https://images.unsplash.com/photo-1507914372368-b2b085cc1450?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Sisterhood gathering" class="relative z-10 rounded-3xl shadow-xl object-cover h-[450px] w-full">
                        </div>
                    </div>
                    <div class="order-1 lg:order-2 fade-in-section">
                        <h3 id="about-title-text" class="font-serif text-3xl md:text-4xl font-bold text-blush-900 dark:text-white mb-6">Nurturing Souls, Building Sisterhood</h3>
                        <p id="about-desc-text" class="text-gray-600 dark:text-gray-300 mb-6 leading-relaxed">
                            Welcome to Hijrah Sisters IIUMK, a sanctuary designed for Muslim women. We are more than just a community; we are a support system dedicated to nurturing each other spiritually, emotionally, and intellectually.
                        </p>
                        <p class="text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
                            In a fast-paced world, we provide a calm, welcoming space to pause, reflect, and reconnect with our Creator and our true selves. We grow together through:
                        </p>
                        <ul class="space-y-4 mb-8">
                            <li class="flex items-center text-gray-700 dark:text-gray-200"><i class="fa-solid fa-heart text-blush-400 mr-3"></i> Weekly Usrah & Heart Talks</li>
                            <li class="flex items-center text-gray-700 dark:text-gray-200"><i class="fa-solid fa-book-open text-blush-400 mr-3"></i> Quran Reflections & Tadabbur</li>
                            <li class="flex items-center text-gray-700 dark:text-gray-200"><i class="fa-solid fa-seedling text-blush-400 mr-3"></i> Personal Development based on Islam</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Our Activities (Icons) -->
        <section id="activities" class="py-20 bg-blush-50 dark:bg-darkBg">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16 fade-in-section">
                    <h3 class="font-serif text-3xl font-bold text-blush-900 dark:text-white">Our Activities</h3>
                    <div class="h-1 w-20 bg-gold mx-auto mt-4 rounded-full"></div>
                </div>
                
                <div id="activities-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
                    <!-- Card 1 -->
                    <div class="bg-white dark:bg-darkCard p-8 rounded-2xl shadow-sm hover:shadow-md transition-shadow text-center fade-in-section group">
                        <div class="w-16 h-16 mx-auto bg-blush-100 dark:bg-blush-900/30 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-users text-2xl text-blush-600 dark:text-blush-300"></i>
                        </div>
                        <h4 class="font-serif font-bold text-lg mb-2 dark:text-white">Weekly Usrah</h4>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Intimate circles sharing reminders and strengthening bonds.</p>
                    </div>
                    <!-- Card 2 -->
                    <div class="bg-white dark:bg-darkCard p-8 rounded-2xl shadow-sm hover:shadow-md transition-shadow text-center fade-in-section group" style="transition-delay: 100ms;">
                        <div class="w-16 h-16 mx-auto bg-blush-100 dark:bg-blush-900/30 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-book-quran text-2xl text-blush-600 dark:text-blush-300"></i>
                        </div>
                        <h4 class="font-serif font-bold text-lg mb-2 dark:text-white">Quran Tadabbur</h4>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Deep reflections on the verses of Allah to heal the heart.</p>
                    </div>
                    <!-- Card 3 -->
                    <div class="bg-white dark:bg-darkCard p-8 rounded-2xl shadow-sm hover:shadow-md transition-shadow text-center fade-in-section group" style="transition-delay: 200ms;">
                        <div class="w-16 h-16 mx-auto bg-blush-100 dark:bg-blush-900/30 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-mug-hot text-2xl text-blush-600 dark:text-blush-300"></i>
                        </div>
                        <h4 class="font-serif font-bold text-lg mb-2 dark:text-white">Book Club</h4>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Reading and discussing beneficial Islamic literature together.</p>
                    </div>
                    <!-- Card 4 -->
                    <div class="bg-white dark:bg-darkCard p-8 rounded-2xl shadow-sm hover:shadow-md transition-shadow text-center fade-in-section group" style="transition-delay: 300ms;">
                        <div class="w-16 h-16 mx-auto bg-blush-100 dark:bg-blush-900/30 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-microphone-lines text-2xl text-blush-600 dark:text-blush-300"></i>
                        </div>
                        <h4 class="font-serif font-bold text-lg mb-2 dark:text-white">Islamic Talks</h4>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Inspiring sessions by guest speakers on various life topics.</p>
                    </div>
                    <!-- Card 5 -->
                    <div class="bg-white dark:bg-darkCard p-8 rounded-2xl shadow-sm hover:shadow-md transition-shadow text-center fade-in-section group" style="transition-delay: 400ms;">
                        <div class="w-16 h-16 mx-auto bg-blush-100 dark:bg-blush-900/30 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-leaf text-2xl text-blush-600 dark:text-blush-300"></i>
                        </div>
                        <h4 class="font-serif font-bold text-lg mb-2 dark:text-white">Reflection Retreats</h4>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Nature outings to reflect on Allah's magnificent creation.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Upcoming Events -->
        <section id="events" class="py-24 bg-white dark:bg-darkCard">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row justify-between items-end mb-12 fade-in-section">
                    <div>
                        <h3 class="font-serif text-3xl font-bold text-blush-900 dark:text-white">Upcoming Events</h3>
                        <p class="text-gray-500 mt-2">Join us in our upcoming gatherings.</p>
                    </div>
                    <!-- Simple filter mockup -->
                    <div class="mt-4 md:mt-0 flex gap-2">
                        <button class="px-4 py-1.5 rounded-full bg-blush-100 text-blush-800 text-sm font-medium">All</button>
                        <button class="px-4 py-1.5 rounded-full text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800 text-sm font-medium transition-colors">This Month</button>
                    </div>
                </div>

                <div id="events-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <!-- Event 1 -->
                    <div class="bg-blush-50 dark:bg-darkBg rounded-3xl overflow-hidden shadow-sm border border-blush-100 dark:border-gray-800 fade-in-section flex flex-col h-full">
                        <img src="https://images.unsplash.com/photo-1544365558-35aa4afcf11f?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Event Image" class="w-full h-48 object-cover">
                        <div class="p-6 flex flex-col flex-grow">
                            <div class="flex gap-2 mb-3">
                                <span class="bg-white dark:bg-darkCard text-blush-600 dark:text-blush-400 text-xs font-bold px-3 py-1 rounded-full shadow-sm">USRAH</span>
                            </div>
                            <h4 class="font-serif text-xl font-bold mb-4 dark:text-white">The Etiquettes of the Seeker</h4>
                            <div class="space-y-2 mb-6 text-sm text-gray-600 dark:text-gray-400 flex-grow">
                                <p><i class="fa-regular fa-calendar text-blush-400 mr-2 w-4"></i> Friday, 24th Nov 2024</p>
                                <p><i class="fa-regular fa-clock text-blush-400 mr-2 w-4"></i> 8:30 PM - 10:00 PM</p>
                                <p><i class="fa-solid fa-location-dot text-blush-400 mr-2 w-4"></i> IIUMK Musolla Female Wing</p>
                            </div>
                            <button class="w-full py-3 rounded-xl border border-blush-500 text-blush-600 dark:text-blush-300 font-medium hover:bg-blush-500 hover:text-white transition-colors">Register via WhatsApp</button>
                        </div>
                    </div>
                    
                    <!-- Event 2 -->
                    <div class="bg-blush-50 dark:bg-darkBg rounded-3xl overflow-hidden shadow-sm border border-blush-100 dark:border-gray-800 fade-in-section flex flex-col h-full" style="transition-delay: 100ms;">
                        <img src="https://images.unsplash.com/photo-1497633762265-9d179a990aa6?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Event Image" class="w-full h-48 object-cover">
                        <div class="p-6 flex flex-col flex-grow">
                            <div class="flex gap-2 mb-3">
                                <span class="bg-white dark:bg-darkCard text-blush-600 dark:text-blush-400 text-xs font-bold px-3 py-1 rounded-full shadow-sm">BOOK CLUB</span>
                            </div>
                            <h4 class="font-serif text-xl font-bold mb-4 dark:text-white">Reclaim Your Heart Discussion</h4>
                            <div class="space-y-2 mb-6 text-sm text-gray-600 dark:text-gray-400 flex-grow">
                                <p><i class="fa-regular fa-calendar text-blush-400 mr-2 w-4"></i> Saturday, 2nd Dec 2024</p>
                                <p><i class="fa-regular fa-clock text-blush-400 mr-2 w-4"></i> 10:00 AM - 12:00 PM</p>
                                <p><i class="fa-solid fa-location-dot text-blush-400 mr-2 w-4"></i> Campus Cafe Area</p>
                            </div>
                            <button class="w-full py-3 rounded-xl border border-blush-500 text-blush-600 dark:text-blush-300 font-medium hover:bg-blush-500 hover:text-white transition-colors">Register via WhatsApp</button>
                        </div>
                    </div>

                    <!-- Event 3 -->
                    <div class="bg-blush-50 dark:bg-darkBg rounded-3xl overflow-hidden shadow-sm border border-blush-100 dark:border-gray-800 fade-in-section flex flex-col h-full" style="transition-delay: 200ms;">
                        <img src="https://images.unsplash.com/photo-1469474968028-56623f02e42e?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Event Image" class="w-full h-48 object-cover">
                        <div class="p-6 flex flex-col flex-grow">
                            <div class="flex gap-2 mb-3">
                                <span class="bg-white dark:bg-darkCard text-blush-600 dark:text-blush-400 text-xs font-bold px-3 py-1 rounded-full shadow-sm">RETREAT</span>
                            </div>
                            <h4 class="font-serif text-xl font-bold mb-4 dark:text-white">Tafakkur in Nature</h4>
                            <div class="space-y-2 mb-6 text-sm text-gray-600 dark:text-gray-400 flex-grow">
                                <p><i class="fa-regular fa-calendar text-blush-400 mr-2 w-4"></i> Sunday, 10th Dec 2024</p>
                                <p><i class="fa-regular fa-clock text-blush-400 mr-2 w-4"></i> 7:30 AM - 11:00 AM</p>
                                <p><i class="fa-solid fa-location-dot text-blush-400 mr-2 w-4"></i> Botanical Gardens</p>
                            </div>
                            <button class="w-full py-3 rounded-xl border border-blush-500 text-blush-600 dark:text-blush-300 font-medium hover:bg-blush-500 hover:text-white transition-colors">Register via WhatsApp</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Resources Section -->
        <section id="resources" class="py-24 bg-beige/30 dark:bg-darkBg">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16 fade-in-section">
                    <h3 class="font-serif text-3xl font-bold text-blush-900 dark:text-white">Nourish Your Soul</h3>
                    <p class="text-gray-600 dark:text-gray-400 mt-3">Curated resources for your spiritual journey.</p>
                    <div class="h-1 w-20 bg-gold mx-auto mt-4 rounded-full"></div>
                </div>

                <div id="resources-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- Resource Cards -->
                    <a href="#" class="group bg-white dark:bg-darkCard p-6 rounded-2xl shadow-sm hover:shadow-lg transition-all fade-in-section border-t-4 border-transparent hover:border-blush-400">
                        <i class="fa-solid fa-pen-nib text-3xl text-blush-300 mb-4 group-hover:text-blush-500 transition-colors"></i>
                        <h4 class="font-serif text-lg font-bold mb-2 dark:text-white">Articles & Reminders</h4>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Short, impactful reflections written by our sisters.</p>
                    </a>
                    
                    <a href="#" class="group bg-white dark:bg-darkCard p-6 rounded-2xl shadow-sm hover:shadow-lg transition-all fade-in-section border-t-4 border-transparent hover:border-blush-400" style="transition-delay: 100ms;">
